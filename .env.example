# Copy to `.env` in this directory before `docker compose up`.
# The real `.env` is gitignored — never commit it.

# --- MySQL (database + api DSN password must match) ---
MYSQL_DATABASE=jobcrawler
MYSQL_USER=jobcrawler
MYSQL_PASSWORD=jobcrawler
MYSQL_ROOT_PASSWORD=root

# --- API ---
API_HTTP_ADDR=:8080
API_JWT_SECRET=dev-secret
API_WORKER_TOKEN=worker-dev-token
API_MYSQL_DSN=jobcrawler:jobcrawler@tcp(mysql:3306)/jobcrawler?parseTime=true

# --- Web (Docker build; browser calls this host) ---
VITE_API_BASE_URL=http://localhost:8080

# --- Worker (WORKER_API_TOKEN must match API_WORKER_TOKEN) ---
WORKER_API_BASE_URL=http://api:8080
WORKER_RUN_INTERVAL=30s
WORKER_REQUEST_TIMEOUT=5s
WORKER_API_TOKEN=worker-dev-token
WORKER_MAX_SYNC_RETRIES=5
WORKER_RETRY_BACKOFF=2s

# --- Email (Brevo: Settings → SMTP & API → SMTP) ---
# Used by the worker (digests) and, under Docker Compose, passed into the API as API_SMTP_* for signup confirmation mail.
WORKER_SMTP_HOST=smtp-relay.brevo.com
WORKER_SMTP_PORT=587
# Brevo “Login” on the SMTP settings page (looks like xxxx@smtp-brevo.com).
WORKER_SMTP_USERNAME=
# Paste the SMTP key from the same Brevo SMTP page (not your Brevo login password).
WORKER_SMTP_PASSWORD=
# REQUIRED for Brevo: a sender email you verified in Brevo (Senders & IP / Domains). NOT the smtp-brevo.com login.
# If this is missing or still "no-reply@jobcrawler.local", Brevo will reject mail and the API log will say so on startup.
WORKER_SMTP_FROM=
# Run the API outside Docker? Export API_SMTP_HOST, API_SMTP_PORT, API_SMTP_USERNAME, API_SMTP_PASSWORD, API_SMTP_FROM (same values as above).
